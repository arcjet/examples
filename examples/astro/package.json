{
  "dependencies": {
    "@arcjet/astro": "1.6.1",
    "@astrojs/node": "10.1.1",
    "@fontsource-variable/figtree": "5.2.10",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "astro": "6.4.8"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.3"
  },
  "name": "@arcjet-examples/astro",
  "overrides": {
    "yaml": ">=2.8.3"
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-astro"
    ],
    "overrides": [
      {
        "files": "*.astro",
        "options": {
          "parser": "astro"
        }
      }
    ]
  },
  "repository": "github:arcjet/example-astro",
  "scripts": {
    "build": "astro build",
    "check": "astro check",
    "dev": "astro dev --host",
    "start": "astro preview --host"
  },
  "type": "module",
  "version": "0.0.0"
}
