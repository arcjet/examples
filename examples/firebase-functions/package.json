{
  "name": "@arcjet-examples/firebase-functions",
  "repository": "github:arcjet/example-firebase-functions",
  "scripts": {
    "check": "tsc",
    "deploy": "firebase deploy --only functions",
    "dev": "firebase emulators:start --only functions",
