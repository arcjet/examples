  },
  "engines": {
    "node": ">=22"
  },
  "main": "src/index.ts",
  "type": "module",
  "dependencies": {
    "@arcjet/inspect": "1.6.1",
    "@arcjet/node": "1.6.1",
    "firebase-admin": "13.10.0",
    "firebase-functions": "7.2.5"
  },
  "devDependencies": {
    "firebase-functions-test": "3.5.0",
    "firebase-tools": "15.22.4",
    "typescript": "5.9.3"
  },
  "private": true,
  "overrides": {
    "http-proxy-agent": ">=7.0.0"
  }
}
